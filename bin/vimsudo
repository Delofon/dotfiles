#!/usr/bin/env bash

# Edit write protected files without running vim as sudo.

set -eu

fin()
{
    rm -r "${TMPDIR}" # unsafe?
}

if [ -z ${1:-} ]
then
    echo "err: filename required" >&2
    exit 1
fi

fil=$1
filname=$(basename "$fil")
TMPDIR=`mktemp -d /tmp/vimsudo.XXXXXX`
TMP="${TMPDIR}/${filname}"

trap fin EXIT

if [ -e "$fil" ]
then
    sudo cat "$fil" > "${TMP}"
fi

$EDITOR "${TMP}"

cat "${TMP}" | sudo tee "$fil" > /dev/null

